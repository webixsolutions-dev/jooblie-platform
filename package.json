{
  "name": "jooblie-platform",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "20.20.2",
    "pnpm": "9.15.9"
  },
  "scripts": {
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "check:site-registry": "node scripts/check-site-registry.mjs",
    "gen:types": "supabase gen types typescript --local | perl -0pe 's/\\n+\\z/\\n/' > packages/core/src/database.types.ts",
    "dev": "turbo run dev"
  },
  "devDependencies": {
    "eslint": "9.39.5",
    "turbo": "2.10.5",
    "typescript": "5.9.3"
  }
}
