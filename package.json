{
  "name": "jooblie-platform",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "20.20.2",
    "pnpm": "9.15.9"
  },
  "scripts": {
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "check:site-registry": "node scripts/check-site-registry.mjs",
    "db:start": "supabase db start",
    "db:reset": "supabase db reset --local",
    "db:stop": "supabase stop --no-backup",
    "gen:types": "bash scripts/generate-database-types.sh",
    "check:db-types": "bash scripts/check-database-types.sh",
    "test:rls": "bash scripts/run-rls-tests.sh",
    "dev": "turbo run dev"
  },
  "devDependencies": {
    "eslint": "9.39.5",
    "supabase": "2.109.1",
    "turbo": "2.10.5",
    "typescript": "5.9.3"
  }
}
