{
  "name": "@jooblie/config",
  "private": true,
  "type": "module",
  "main": "./eslint.config.js",
  "exports": {
    ".": "./eslint.config.js",
    "./eslint": "./eslint.config.js",
    "./tailwind": "./tailwind.preset.js",
    "./tsconfig.base.json": "./tsconfig.base.json"
  },
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
